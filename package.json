{
  "name": "delta-gate",
  "version": "0.2.0",
  "description": "Run commands when git diff changes are detected",
  "license": "MIT",
  "author": {
    "name": "fcamblor"
  },
  "type": "module",
  "bin": {
    "delta-gate": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picomatch": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "~5.8.0",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
